{{> header}}
    <section class="container main">
    {{>asidebar}}
        <section class="feed mt-10">
            
            <div class="row">
                <div class="column pr-5">
                    {{>feed-input}}

                    {{#posts}}

                    <div class="box feed-item" data-id="{{id}}">
                        <div class="box-body">
                            <div class="feed-item-head row mt-20 m-width-20">
                                <div class="feed-item-head-photo">
                                    <a href="/perfil/{{id_user}}"><img src="/media/avatars/avatar.jpg" /></a>
                                </div>
                                <div class="feed-item-head-info">
                                    <a href=""><span class="fidi-name">{{name}} </span></a>
                                    <span class="fidi-action">fez um post</span>
                                    <br/>
                                    <span class="fidi-date">{{created_at}}</span>
                                </div>
                                <div class="feed-item-head-btn">
                                    <img src="/assets/images/more.png" />
                                </div>
                            </div>
                            <div class="feed-item-body mt-10 m-width-20">
                                {{body}}
                            </div>
                            <div class="feed-item-buttons row mt-20 m-width-20">
                                <div class="like-btn {{#isLiked}} on {{/isLiked}}">{{likeCount}}</div>
                                <div class="msg-btn">{{countComment}}</div>
                            </div>
                            <div class="feed-item-comments"> 
                                <div class="feed-item-comments-area">
                                    {{#postComment}}
                                    <div class="fic-item row m-height-10 m-width-20">
                                        <div class="fic-item-photo">
                                            <a href="/perfil/{{id_user}}"><img src="/media/avatars/avatar.jpg" /></a>
                                        </div>
                                        <div class="fic-item-info">
                                            <a href="/perfil/{{id_user}}">{{user.name}}</a>
                                            {{body}}
                                        </div>
                                    </div>
                                    {{/postComment}}
                                </div>
                                <div class="fic-answer row m-height-10 m-width-20">
                                    <div class="fic-item-photo">
                                        <a href=""><img src="/media/avatars/avatar.jpg" /></a>
                                    </div>
                                    <input type="text" class="fic-item-field" placeholder="Escreva um comentário" />
                                </div>
                            </div>
                        </div>
                    </div>


                    {{/posts}}


                    

                </div>
          {{>ads}}

        </section>
    </section>
    <div class="modal">
        <div class="modal-inner">
            <a rel="modal:close">&times;</a>
            <div class="modal-content"></div>
        </div>
    </div>
    <script type="text/javascript" src="/assets/js/script.js"></script>
    <script type="text/javascript" src="/assets/js/vanillaModal.js"></script>

    {{> footer}}
