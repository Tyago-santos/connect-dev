<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Conect Dev</title>
    <meta name="viewport" content="width=device-width,minimum-scale=1,initial-scale=1"/>
    <link rel="stylesheet" href="assets/css/login.css" />
</head>
<body class="page-login">
    <header>
        <div class="container">
            <a href=""><img src="assets/images/conectdev_logo.svg" /></a>
        </div>
    </header>
    <section class="container main">
        <div class="message">{{message}}</div>
        <form method="POST" action="/register_action">
            <input placeholder="Digite seu nome" class="input" name="name" />
            <input placeholder="Digite seu e-mail" class="input" name="email" />
            <input placeholder="Digite sua senha" class="input" type="password" name="password" />

            <input class="button" type="submit" value="Acessar o sistema" />

            <a href="/login">Ainda não tem conta? Cadastre-se</a>
        </form>
    </section>
    {{> footer}}

</body>
</html>
